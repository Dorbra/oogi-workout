# Cloudflare Pages cache rules
#
# index.html — always revalidate. Never serve a stale shell to the PWA.
# Vite content-hashes every JS/CSS filename, so those assets never change
# at a given URL and can be cached forever.
/index.html
  Cache-Control: no-cache

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: no-cache

/registerSW.js
  Cache-Control: no-cache

/manifest.webmanifest
  Cache-Control: no-cache
